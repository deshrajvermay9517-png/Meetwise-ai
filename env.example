# .env.example — copy to .env.local

# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# OpenAI (Whisper transcription + embeddings)
OPENAI_API_KEY=sk-...

# Anthropic (Claude - summaries, actions, sentiment, search)
ANTHROPIC_API_KEY=sk-ant-...

# Razorpay (payments — add real keys after completing KYC)
# Get these from: https://dashboard.razorpay.com/app/keys
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
# Get this from: Razorpay Dashboard → Webhooks → your webhook → Signing Secret
RAZORPAY_WEBHOOK_SECRET=

# Resend (transactional email)
RESEND_API_KEY=re_...
RESEND_FROM_EMAIL=noreply@yourdomain.com

# App
NEXT_PUBLIC_APP_URL=http://localhost:3001

# Cron (set a long random string, add to Vercel env vars)
CRON_SECRET=your-random-secret-here
